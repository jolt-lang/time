;; tick provides the idiomatic Clojure time API on top of the java.time.* shim in
;; src/. tick's own transitive deps — cljc.java-time and time-literals — resolve
;; from Maven automatically (jolt fetches the source from the JAR). time-literals
;; is still vendored: its #time data-readers use the (. Class parse) dot-form,
;; which jolt doesn't yet compile (jolt-5hnv), so the vendored copy carries the
;; equivalent slash-form; being on :paths it shadows the Maven one.
{:paths ["src" "vendor/time-literals"]

 :deps {io.github.juxt/tick
        {:git/url "https://github.com/juxt/tick.git"
         :git/sha "3c2cc4e809c21476f63470cd3e5cb2ff8fa5ef69"}}

 :aliases
 {:test {:extra-paths ["test" "vendor/tick-test" "vendor/spec-alpha"]
         :main-opts ["-m" "jolt.time-test-runner"]}

  :stage {:extra-paths ["test"]
          :main-opts ["-m" "jolt.time.stage-test"]}}

 :tasks {test "joltc -M:test"}}
